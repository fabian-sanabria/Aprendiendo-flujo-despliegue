# ─────────────────────────────────────────────────────────────────────────────
# MercaSimple — Environment variables template
# Copy to .env and fill in real values before running:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=3600

# ── Auth DB ───────────────────────────────────────────────────────────────────
AUTH_DB_NAME=auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=changeme_auth

# ── Catalog DB ────────────────────────────────────────────────────────────────
CATALOG_DB_NAME=catalog
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=changeme_catalog

# ── Orders DB ─────────────────────────────────────────────────────────────────
ORDERS_DB_NAME=orders
ORDERS_DB_USER=orders_user
ORDERS_DB_PASSWORD=changeme_orders

# ── Payments DB ───────────────────────────────────────────────────────────────
PAYMENTS_DB_NAME=payments
PAYMENTS_DB_USER=payments_user
PAYMENTS_DB_PASSWORD=changeme_payments

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
